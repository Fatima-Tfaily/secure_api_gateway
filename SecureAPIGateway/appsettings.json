{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "JwtSettings": {
    "SecretKey": "CHANGE_ME_USE_ENV_VAR_IN_PRODUCTION_MIN32CHARS",
    "Issuer": "SecureAPIGateway",
    "Audience": "SecureAPIGatewayUsers",
    "ExpiryMinutes": 1440
  },

  "RateLimitSettings": {
    "MaxRequestsPerWindow": 5,
    "WindowSeconds": 60
  },

  "AiServiceSettings": {
    "BaseUrl": "http://localhost:5001",
    "TimeoutSeconds": 5
  }
}